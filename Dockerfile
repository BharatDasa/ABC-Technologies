###############################################################################
# Stage 1 - Build
###############################################################################

FROM maven:3.9.11-eclipse-temurin-17 AS builder

WORKDIR /build

COPY pom.xml .

RUN mvn dependency:go-offline

COPY src ./src

RUN mvn clean package -DskipTests

###############################################################################
# Stage 2 - Runtime
###############################################################################

FROM tomcat:10.1-jdk17-temurin

LABEL maintainer="Bharat Dasa"
LABEL application="ABC-Technologies"
LABEL environment="Production"

###############################################################################
# Clean Default Applications
###############################################################################

RUN rm -rf \
    /usr/local/tomcat/webapps/*

###############################################################################
# Deploy Application
###############################################################################

COPY --from=builder \
    /build/target/*.war \
    /usr/local/tomcat/webapps/ROOT.war

###############################################################################
# Expose Port
###############################################################################

EXPOSE 8080

###############################################################################
# Health Check
###############################################################################

HEALTHCHECK \
    --interval=30s \
    --timeout=5s \
    --start-period=60s \
    --retries=3 \
CMD curl -f http://localhost:8080/ || exit 1

###############################################################################
# Start Tomcat
###############################################################################

CMD ["catalina.sh","run"]